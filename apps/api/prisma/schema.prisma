// ─────────────────────────────────────────────────────────────────────────────
// Ares Station — Prisma Schema
// Database: PostgreSQL
// ORM:      Prisma
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Player ────────────────────────────────────────────────────────────────────
// One row per Telegram user. Created on first successful auth.
// tgUserId is a String because Telegram IDs exceed JavaScript's safe integer
// range on some platforms — safer to store as text and cast when needed.
// balance is in-game currency units, not real money.

model Player {
  id           String   @id @default(uuid())
  tgUserId     String   @unique           // Telegram user ID stored as string
  username     String?
  firstName    String
  lastName     String?
  languageCode String?
  isPremiumTg  Boolean  @default(false)
  balance      Int      @default(0)
  createdAt    DateTime @default(now())
  lastSeenAt   DateTime @default(now()) @updatedAt

  // Relations
  playerDays   PlayerDay[]
  paradoxLogs  ParadoxLog[]
  transactions Transaction[]

  // Operator Drills
  drillStats    PlayerDrillStat[]
  workouts      WorkoutSession[]
  drillStreak   PlayerDrillStreak?
  codexUnlocks  PlayerCodexUnlock[]

  @@map("players")
}

// ── Day ───────────────────────────────────────────────────────────────────────
// One row per story day. Content is immutable once published.
// content Json: full document sent to client { title, stardate, theme, document[], puzzles[], finale }
// answers Json: server-only answer key { [slot]: { answer, unlockWord, hint } }
//              answers column is NEVER included in API responses to the client.

model Day {
  id          String   @id                // e.g. "s1-d001"
  season      Int
  dayNumber   Int
  publishedAt DateTime
  content     Json                        // client-safe document blob
  answers     Json                        // server-only answer key

  // Relations
  playerDays  PlayerDay[]
  paradoxLogs ParadoxLog[]

  @@unique([season, dayNumber])
  @@index([publishedAt])
  @@map("days")
}

// ── PlayerDay ─────────────────────────────────────────────────────────────────
// Core progression table. One row per player per unlocked day.
//
// Personal-synchronous gate lives in unlockedAt:
//   - Day 1 inserted with unlockedAt = now() on enrollment
//   - Completing day N inserts day N+1 with unlockedAt = now() + 24h
//   - "Skip wait" purchase: UPDATE SET unlockedAt = now()
//   - Current available day = MAX(dayNumber) WHERE unlockedAt <= now()
//
// solvedSlots Json: { [slot]: true } — which puzzles are solved
// unlockWords String[]: accumulated words for Paradox interrogation

model PlayerDay {
  id           String    @id @default(uuid())
  playerId     String
  dayId        String
  unlockedAt   DateTime                   // gate — may be in the future
  startedAt    DateTime?
  completedAt  DateTime?
  solvedSlots  Json      @default("{}")   // { "s1": true, "s2": true, ... }
  unlockWords  String[]  @default([])
  paradoxWin   Boolean   @default(false)
  attemptsUsed Int       @default(0)

  // Relations
  player Player @relation(fields: [playerId], references: [id])
  day    Day    @relation(fields: [dayId],    references: [id])

  @@unique([playerId, dayId])
  @@index([playerId, unlockedAt])
  @@map("player_days")
}

// ── ParadoxLog ────────────────────────────────────────────────────────────────
// Full conversation history per player per day.
// Stored to reconstruct context for resumed sessions and
// to analyse what players ask (signal for content improvement).
// role: "user" | "assistant"

model ParadoxLog {
  id         String   @id @default(uuid())
  playerId   String
  dayId      String
  role       String
  content    String
  tokensUsed Int?
  createdAt  DateTime @default(now())

  // Relations
  player Player @relation(fields: [playerId], references: [id])
  day    Day    @relation(fields: [dayId],    references: [id])

  @@index([playerId, dayId])
  @@map("paradox_logs")
}

// ── Transaction ───────────────────────────────────────────────────────────────
// Append-only currency ledger. Never update or delete rows.
// Balance is always derived as SUM(amount) — never stored as a mutable field.
// amount: positive = credit, negative = debit
// type:   "purchase" | "reward" | "refund" | "skip_wait" | "hint" | "streak_save"
//         | "drill_reward"

model Transaction {
  id        String   @id @default(uuid())
  playerId  String
  type      String
  amount    Int                            // positive = credit, negative = debit
  itemId    String?
  dayId     String?
  metadata  Json?
  createdAt DateTime @default(now())

  // Relations
  player Player @relation(fields: [playerId], references: [id])

  @@index([playerId])
  @@map("transactions")
}

// ─────────────────────────────────────────────────────────────────────────────
// OPERATOR DRILLS
// Side-mode mini-games. Mechanically independent of the main story.
// See OPERATOR_DRILLS_ROADMAP.md for full design.
// ─────────────────────────────────────────────────────────────────────────────

// ── PlayerDrillStat ───────────────────────────────────────────────────────────
// One row per player per drill type. Tracks personal best and mastery tier.
// drillType: "cipher" | "sensor" | "pattern" | "drift" (v1)
// masteryTier: "none" | "bronze" | "silver" | "gold"

model PlayerDrillStat {
  id                String   @id @default(uuid())
  playerId          String
  drillType         String
  bestScore         Int      @default(0)
  masteryTier       String   @default("none")
  totalSessions     Int      @default(0)
  totalRoundsPlayed Int      @default(0)
  updatedAt         DateTime @updatedAt

  player Player @relation(fields: [playerId], references: [id])

  @@unique([playerId, drillType])
  @@map("player_drill_stats")
}

// ── WorkoutSession ────────────────────────────────────────────────────────────
// One row per player per UTC day. Daily Workout completion record.
// drillsPlayed Json: [{ drillType: string, score: number }, ...]
// Daily-uniqueness enforced via @@unique([playerId, utcDay]).
// utcDay format: "YYYY-MM-DD"

model WorkoutSession {
  id              String   @id @default(uuid())
  playerId        String
  utcDay          String
  drillsPlayed    Json
  integrityScore  Int
  currencyAwarded Int      @default(0)
  completedAt     DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id])

  @@unique([playerId, utcDay])
  @@index([playerId, completedAt])
  @@map("workout_sessions")
}

// ── PlayerDrillStreak ─────────────────────────────────────────────────────────
// Single row per player. Tracks consecutive-day Daily Workout completion.
// lastWorkoutDay format: "YYYY-MM-DD" — the UTC day of the last completed workout.

model PlayerDrillStreak {
  id              String   @id @default(uuid())
  playerId        String   @unique
  currentStreak   Int      @default(0)
  longestStreak   Int      @default(0)
  lastWorkoutDay  String?
  updatedAt       DateTime @updatedAt

  player Player @relation(fields: [playerId], references: [id])

  @@map("player_drill_streaks")
}

// ── CodexEntry ────────────────────────────────────────────────────────────────
// World-flavored articles unlocked by drill performance. Atmospheric only —
// never carries main-story content (architectural invariant).
// unlockType: "drill_score" | "drill_mastery" | "workout_streak"
// unlockCondition Json: shape depends on unlockType, e.g.
//   { drillType: "cipher", threshold: 12 }   // for drill_score / drill_mastery
//   { streak: 7 }                            // for workout_streak

model CodexEntry {
  id              String   @id
  title           String
  body            String
  unlockType      String
  unlockCondition Json
  sortOrder       Int      @default(0)

  unlocks PlayerCodexUnlock[]

  @@map("codex_entries")
}

// ── PlayerCodexUnlock ─────────────────────────────────────────────────────────
// Append-only record of which codex entries each player has unlocked.

model PlayerCodexUnlock {
  id           String   @id @default(uuid())
  playerId     String
  codexEntryId String
  unlockedAt   DateTime @default(now())

  player Player     @relation(fields: [playerId], references: [id])
  entry  CodexEntry @relation(fields: [codexEntryId], references: [id])

  @@unique([playerId, codexEntryId])
  @@index([playerId])
  @@map("player_codex_unlocks")
}
