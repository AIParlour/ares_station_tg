# ─────────────────────────────────────────────────────────────────────────────
# Ares Station API — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string
# Local dev (docker-compose): postgresql://ares:ares_dev_password@localhost:5432/ares_station
# Production (RDS / EC2):     postgresql://user:password@host:5432/ares_station
DATABASE_URL=postgresql://ares:ares_dev_password@localhost:5432/ares_station

# Telegram Bot token from @BotFather
# Leave empty in dev to skip HMAC validation (mock user will be used)
BOT_TOKEN=

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=change_me_in_production

# Server port
PORT=3000

# Anthropic API key for Paradox (Claude)
ANTHROPIC_API_KEY=

# Environment
NODE_ENV=development
